{
  "name": "almost-codex",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm run compile",
    "compile": "npm run clean && npm run test && tsc && npm run copy-settings && npm run copy-tool-registry && npm run copy-prompts",
    "clean": "rm -rf dist",
    "copy-settings": "node -e \"require('fs').cpSync('src/settings','dist/settings',{recursive:true,force:true})\"",
    "copy-tool-registry": "node -e \"require('fs').mkdirSync('dist/tools/registry',{recursive:true});require('fs').copyFileSync('src/tools/registry/ToolRegistry.json','dist/tools/registry/ToolRegistry.json')\"",
    "copy-prompts": "node -e \"require('fs').cpSync('src/prompts','dist/prompts',{recursive:true,force:true});require('fs').cpSync('src/personalities','dist/personalities',{recursive:true,force:true})\"",
    "script": "node ./dist/index.js",
    "test": "jest --config jest.config.js --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyler-bartschi/almost-codex.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tyler-bartschi/almost-codex/issues"
  },
  "homepage": "https://github.com/tyler-bartschi/almost-codex#readme",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.2",
    "@types/prompt-sync": "^4.2.3",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-mockito": "npm:@typestrong/ts-mockito@^2.7.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.31.0",
    "prompt-sync": "^4.2.0",
    "yaml": "^2.8.2"
  }
}
